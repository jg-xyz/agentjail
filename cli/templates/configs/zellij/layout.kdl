// Zellij layout for agentjail — rendered by writeZellijFiles at launch time.
// Variables: {{.AgentTabName}}, {{.Shell}}, .BottomBar
// Keybinds are defined in config.kdl (same directory); hints.sh is auto-generated from them.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
{{.BottomBar}}
    }
    tab name="{{.AgentTabName}}" focus=true {
        pane command="/root/.agentjail/zellij/tabs/agent.sh" {
            cwd "/project"
        }
    }
    tab name="terminal" {
        pane command="{{.Shell}}" {
            cwd "/project"
        }
    }
    tab name="files" {
        pane command="/root/.agentjail/zellij/tabs/files.sh" {
            cwd "/project"
        }
    }
}
